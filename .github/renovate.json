{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "pinDigests": true,
  "ignoreUnstable": false,
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "yaml",
      "managerFilePatterns": [
        "/^packages.yaml$/"
      ],
      "matchStrings": [
        "packages.{\"depName\": repo, \"currentValue\": version}"
      ],
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "*"
      ],
      "automerge": true
    }
  ],
  "versioning": "loose"
}
